			<staticText>
				<reportElement positionType="Float" x="0" y="259" width="430" height="49" uuid="97d3daa1-20f7-486a-b619-f4b76bb33d38"/>
				<textElement textAlignment="Center">
					<font size="12" isBold="true"/>
				</textElement>
				<text><![CDATA[NO REGISTRA DENUNCIA, ACUSACIÓN, INVESTIGACIÓN PRELIMINAR, PROCESO DE ENJUICIAMIENTO EN TRÁMITE NI SENTENCIA SANCIONATORIA ANTE ESTE ÓRGANO CONSTITUCIONAL.]]></text>
			</staticText>
			<image>
				<reportElement x="10" y="14" width="420" height="50" uuid="26e0632d-4fb7-4e84-af1c-a1d4c8866673"/>
				<imageExpression><![CDATA["logoJEM.png"]]></imageExpression>
			</image>
			<staticText>
				<reportElement x="10" y="70" width="421" height="41" uuid="f6aab18c-f0c7-41ee-a6b6-c067642a6914"/>
				<textElement>
					<font size="8" isItalic="true"/>
				</textElement>
				<text><![CDATA[Misión: Juzgar el desempeño de los Magistrados Judiciales, Agentes Fiscales y Defensores Públicos, por la supuesta comisión de delitos o mal desempeño en el ejercicio de sus funciones, con imparcialidad, transparencia y justicia.]]></text>
			</staticText>
			<staticText>
				<reportElement positionType="Float" x="0" y="311" width="431" height="21" uuid="14c8f768-e180-4dac-9dd5-55587520b529">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
				</reportElement>
				<textElement textAlignment="Center">
					<font size="8" isItalic="false"/>
				</textElement>
				<text><![CDATA[Obs. El presente informe de antecedentes corresponde a los últimos cinco años, conforme a los registros obrantes en la Secretaría General.]]></text>
			</staticText>
			<line>
				<reportElement positionType="Float" x="10" y="357" width="420" height="1" uuid="945fb44b-516f-4d03-96bd-45270a64c813">
